{
  "expo": {
    "name": "Runde",
    "slug": "runde",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "runde",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C52A87"
    },
    "ios": {
      "bundleIdentifier": "com.runde.app",
      "buildNumber": "4",
      "icon": "./assets/icon.png",
      "supportsTablet": false
    },
    "android": {
      "package": "com.runde.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#C52A87"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
